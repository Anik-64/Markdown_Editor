<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Real-Time Markdown Editor</title>
    <meta name="description" content="A modern, real-time Markdown editor with instant preview and PDF export.">
    <meta name="keywords" content="Markdown editor, markdown editor free, real-time preview, Markdown viewer, instant Markdown preview, online Markdown editor, text formatting, writing tools">
    <meta name="author" content="Anik Majumder">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'brand-dark': '#1e293b',
                        'brand-light': '#f8fafc',
                    }
                }
            }
        }
    </script>
    
    <!-- Custom CSS (Scrollbar & Markdown) -->
    <style type="text/tailwindcss">
        @layer base {
            body { @apply bg-brand-light text-brand-dark transition-colors duration-300; }
            html.dark body { @apply bg-slate-900 text-slate-100; }
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { @apply bg-slate-300 rounded-full; }
        html.dark ::-webkit-scrollbar-thumb { @apply bg-slate-700; }
        ::-webkit-scrollbar-thumb:hover { @apply bg-slate-400; }
        html.dark ::-webkit-scrollbar-thumb:hover { @apply bg-slate-600; }

        .markdown-body { @apply font-sans leading-relaxed text-slate-800 break-words; }
        html.dark .markdown-body { @apply text-slate-200; }
        .markdown-body h1 { @apply text-4xl font-bold mb-6 mt-8 pb-2 border-b border-slate-200; }
        html.dark .markdown-body h1 { @apply border-slate-700; }
        .markdown-body h2 { @apply text-3xl font-semibold mb-5 mt-8 pb-2 border-b border-slate-200; }
        html.dark .markdown-body h2 { @apply border-slate-700; }
        .markdown-body h3 { @apply text-2xl font-semibold mb-4 mt-6; }
        .markdown-body h4 { @apply text-xl font-semibold mb-4 mt-6; }
        .markdown-body p { @apply mb-4; }
        .markdown-body ul { @apply list-disc list-outside mb-4 ml-6; }
        .markdown-body ol { @apply list-decimal list-outside mb-4 ml-6; }
        .markdown-body li { @apply mb-1; }
        .markdown-body a { @apply text-blue-600 hover:underline; }
        html.dark .markdown-body a { @apply text-blue-400; }
        .markdown-body code { @apply bg-slate-100 text-slate-800 px-1.5 py-0.5 rounded font-mono text-sm; }
        html.dark .markdown-body code { @apply bg-slate-800 text-slate-200; }
        .markdown-body pre { @apply bg-slate-100 p-4 rounded-lg whitespace-pre-wrap break-words mb-4; }
        html.dark .markdown-body pre { @apply bg-slate-800; }
        .markdown-body pre code { @apply bg-transparent p-0 text-inherit; }
        .markdown-body blockquote { @apply border-l-4 border-slate-300 pl-4 py-1 mb-4 italic text-slate-600 bg-slate-50; }
        html.dark .markdown-body blockquote { @apply border-slate-600 text-slate-400 bg-slate-800/50; }
        .markdown-body img { @apply max-w-full h-auto rounded shadow-sm my-4; }
        .markdown-body hr { @apply my-8 border-slate-200; }
        html.dark .markdown-body hr { @apply border-slate-700; }
        .markdown-body table { @apply w-full mb-4 border-collapse text-left; }
        .markdown-body th { @apply font-semibold bg-slate-100 px-4 py-2 border border-slate-300; }
        html.dark .markdown-body th { @apply bg-slate-800 border-slate-600; }
        .markdown-body td { @apply px-4 py-2 border border-slate-300; }
        html.dark .markdown-body td { @apply border-slate-600; }
        
        body { font-family: 'Inter', sans-serif; }
        .editor-container { font-family: 'JetBrains Mono', monospace; }
        
        #loading { position: fixed; inset: 0; background: var(--bg-color, #ffffff); z-index: 50; display: flex; align-items: center; justify-content: center; transition: opacity 0.3s; }
        html.dark #loading { background: #0f172a; color: white; }
    </style>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- html2pdf -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        body { font-family: 'Inter', sans-serif; }
        .editor-container { font-family: 'JetBrains Mono', monospace; }
        
        /* Loading Overlay */
        #loading {
            position: fixed;
            inset: 0;
            background: var(--bg-color, #ffffff);
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s;
        }
        html.dark #loading { background: #0f172a; color: white; }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-slate-100 transition-colors duration-200">

    <div id="loading">
        <i class="ph ph-spinner-gap animate-spin text-4xl text-blue-500"></i>
    </div>

    <!-- Header / Toolbar -->
    <header class="flex-none h-14 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-sm flex items-center justify-between px-4 z-10">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded bg-blue-500 text-white flex items-center justify-center font-bold text-xl">M<span class="text-blue-200 text-sm mt-1">↓</span></div>
            <h1 class="font-semibold text-lg hidden sm:block">Markdown Editor</h1>
        </div>

        <!-- Toolbar Tools -->
        <div class="flex items-center gap-1 sm:gap-2">
            <button onclick="window.editorAction('bold')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Bold (Ctrl+B)">
                <i class="ph ph-text-b"></i>
            </button>
            <button onclick="window.editorAction('italic')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Italic (Ctrl+I)">
                <i class="ph ph-text-italic"></i>
            </button>
            <button onclick="window.editorAction('strikethrough')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors hidden sm:block" title="Strikethrough">
                <i class="ph ph-text-strikethrough"></i>
            </button>
            
            <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-1"></div>
            
            <button onclick="window.editorAction('heading')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Heading">
                <i class="ph ph-text-h"></i>
            </button>
            <button onclick="window.editorAction('quote')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Quote">
                <i class="ph ph-quotes"></i>
            </button>
            <button onclick="window.editorAction('code')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Code">
                <i class="ph ph-code"></i>
            </button>
            
            <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-1"></div>
            
            <button onclick="window.editorAction('link')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Link">
                <i class="ph ph-link"></i>
            </button>
            <button onclick="window.editorAction('image')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors hidden sm:block" title="Image">
                <i class="ph ph-image"></i>
            </button>
            <button onclick="window.editorAction('ul')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Unordered List">
                <i class="ph ph-list-bullets"></i>
            </button>
            <button onclick="window.editorAction('ol')" class="p-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors hidden sm:block" title="Ordered List">
                <i class="ph ph-list-numbers"></i>
            </button>
        </div>

        <!-- Global Actions -->
        <div class="flex items-center gap-2">
            <button id="themeToggle" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-colors" title="Toggle Theme">
                <i class="ph ph-moon dark:hidden"></i>
                <i class="ph ph-sun hidden dark:block text-yellow-400"></i>
            </button>
            <button onclick="exportPDF()" class="flex items-center gap-2 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded text-sm font-medium transition-colors" title="Export to PDF">
                <i class="ph ph-download-simple"></i>
                <span class="hidden sm:inline">Export</span>
            </button>
        </div>
    </header>

    <!-- Mobile Tabs -->
    <div class="flex-none flex md:hidden bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
        <button id="tab-edit" class="flex-1 py-3 text-sm font-medium border-b-2 border-blue-600 text-blue-600 dark:text-blue-400" onclick="switchTab('edit')">Editor</button>
        <button id="tab-preview" class="flex-1 py-3 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" onclick="switchTab('preview')">Preview</button>
    </div>

    <!-- Main Workspace -->
    <main class="flex-1 flex overflow-hidden relative">
        <!-- Editor Pane -->
        <div id="pane-edit" class="flex-1 flex flex-col h-full md:flex border-r border-slate-200 dark:border-slate-700 w-full md:w-1/2 absolute md:relative z-10 bg-white dark:bg-slate-900 transition-transform duration-300 transform md:transform-none translate-x-0">
            <div id="editor-container" class="flex-1 w-full h-full"></div>
        </div>

        <!-- Preview Pane -->
        <div id="pane-preview" class="flex-1 flex flex-col h-full md:flex w-full md:w-1/2 absolute md:relative bg-slate-50 dark:bg-slate-900 md:transform-none transform translate-x-full md:translate-x-0 transition-transform duration-300">
            <div id="preview-content" class="flex-1 w-full h-full p-6 md:p-8 overflow-y-auto markdown-body">
            
            </div>
        </div>
    </main>

    <!-- Showdown.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/showdown/2.1.0/showdown.min.js"></script>
    
    <!-- RequireJS & Monaco Editor -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/require.js/2.3.6/require.min.js"></script>
    <script src="/js/script.js"></script>

</body>
</html>
